{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "naam": {
          "type": "string",
          "description": "User's first name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        },
        "school": {
          "type": "string",
          "description": "User's school name"
        },
        "jaar": {
          "type": "string",
          "description": "User's current school year"
        },
        "leeftijd": {
          "type": "string",
          "description": "User's age"
        },
        "richting": {
          "type": "string",
          "description": "User's study direction"
        },
        "vakken": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "number" },
              "naam": { "type": "string" },
              "isHoofdvak": { "type": "boolean" },
              "punt": { "type": "string" },
              "maxPunt": { "type": "string" }
            }
          },
          "description": "List of subjects and grades"
        },
        "gedragAntw": {
          "type": "object",
          "description": "User's answers to behavior questions"
        },
        "score": {
          "type": "number",
          "description": "User's calculated score"
        },
        "xp": {
          "type": "number",
          "description": "User's experience points"
        },
        "rank": {
          "type": "string",
          "description": "User's current rank"
        },
        "focusPoints": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "completed": { "type": "boolean" },
              "xpValue": { "type": "number" },
              "createdAt": { "type": "string", "format": "date-time" }
            }
          },
          "description": "List of focus points (goals) for the user"
        },
        "badges": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of earned badge IDs"
        },
        "customBadges": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" },
              "requirementText": { "type": "string" }
            }
          },
          "description": "List of dynamically generated badges"
        }
      },
      "required": ["naam", "email"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback about the application",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "rating": { "type": "number" }
      },
      "required": ["message", "timestamp"]
    },
    "Progression": {
      "title": "Progression",
      "description": "Daily score recordings for progression tracking",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "score": { "type": "number" },
        "date": { "type": "string", "description": "YYYY-MM-DD format" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "score", "date", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "User feedback documents"
    },
    "/users/{userId}/progression/{date}": {
      "schema": "Progression",
      "description": "Daily progression records"
    }
  }
}
