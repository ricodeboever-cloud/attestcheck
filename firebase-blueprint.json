{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "naam": {
          "type": "string",
          "description": "User's first name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        }
      },
      "required": ["naam", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    }
  }
}
