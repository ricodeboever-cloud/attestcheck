rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ═══════════════════════════════════════════════════════════════════════
    // 🔒 HELPERS
    // ═══════════════════════════════════════════════════════════════════════
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // 👤 USERS
    // ═══════════════════════════════════════════════════════════════════════
    function isValidUser(data) {
      return data.naam is string && data.naam.size() <= 100 &&
             data.email is string && data.email.size() <= 150 &&
             (!('xp' in data) || data.xp is number) &&
             (!('rank' in data) || data.rank is string) &&
             (!('focusPoints' in data) || data.focusPoints is list);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming());
      allow delete: if isOwner(userId);

      // Subcollection for progression tracking
      match /progression/{date} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && 
                      incoming().score is number && 
                      incoming().date is string &&
                      incoming().timestamp is timestamp;
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }

    // ═══════════════════════════════════════════════════════════════════════
    // 💡 FEEDBACK
    // ═══════════════════════════════════════════════════════════════════════
    function isValidFeedback(data) {
      return data.message is string && data.message.size() <= 2000 &&
             data.userId == request.auth.uid &&
             (!('rating' in data) || (data.rating is number && data.rating >= 1 && data.rating <= 5)) &&
             data.timestamp == request.time;
    }

    match /feedback/{feedbackId} {
      allow create: if isSignedIn() && isValidFeedback(incoming());
      // Admins (hypothetical) would need a different rule, for now users just submit.
      allow read, update, delete: if false;
    }
  }
}
