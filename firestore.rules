rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ═══════════════════════════════════════════════════════════════════════
    // 🔒 HELPERS
    // ═══════════════════════════════════════════════════════════════════════
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // ═══════════════════════════════════════════════════════════════════════
    // 👤 USERS
    // ═══════════════════════════════════════════════════════════════════════
    function isValidUser(data) {
      return data.naam is string && data.naam.size() <= 100 &&
             data.email is string && data.email.size() <= 150 &&
             (!('xp' in data) || data.xp is number) &&
             (!('rank' in data) || data.rank is string) &&
             (!('focusPoints' in data) || data.focusPoints is list);
    }

    match /users/{userId} {
      // Identity Check: Only owners can access their profile
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isOwner(userId);
      
      // Validation Blueprint: Strict schema for user profiles
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().email == request.auth.token.email;
      
      allow update: if isOwner(userId) && isValidUser(incoming()) &&
                    incoming().email == existing().email &&
                    incoming().uid == existing().uid;

      // Subcollection for progression tracking
      match /progression/{date} {
        // Enforce secure list queries
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        
        allow create: if isOwner(userId) && 
                      incoming().score is number && 
                      incoming().date == date &&
                      incoming().userId == request.auth.uid &&
                      incoming().timestamp == request.time;
                      
        allow update: if isOwner(userId) && 
                      incoming().score is number &&
                      incoming().date == existing().date &&
                      incoming().userId == existing().userId &&
                      incoming().timestamp == request.time;
        
        allow delete: if isOwner(userId);
      }
    }

    // ═══════════════════════════════════════════════════════════════════════
    // 💡 FEEDBACK
    // ═══════════════════════════════════════════════════════════════════════
    function isValidFeedback(data) {
      return data.message is string && data.message.size() <= 2000 &&
             data.userId == request.auth.uid &&
             (!('rating' in data) || (data.rating is number && data.rating >= 1 && data.rating <= 5)) &&
             data.timestamp == request.time;
    }

    match /feedback/{feedbackId} {
      allow create: if isSignedIn() && isValidFeedback(incoming());
      allow read, update, delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════
    // 🧪 MISC
    // ═══════════════════════════════════════════════════════════════════════
    match /test/connection {
      allow get: if true;
    }

    // Default Deny (Fallback)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
